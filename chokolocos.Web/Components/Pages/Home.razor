@page "/"
@page "/home"
@using chokolocos.Web.Models
@inject IJSRuntime JS

<PageTitle>Inicio | chokolocos</PageTitle>

<!-- Hero Section -->
<section class="hero-section row align-items-center py-5 mb-5 reveal">
    <div class="col-lg-6 mb-4 mb-lg-0 text-center text-lg-start">
        <h1 class="sweets-delight display-1 mb-3 text-pink" style="color: var(--color-pink);">Momentos Dulces</h1>
        <h2 class="font-heading fw-bold mb-4" style="font-size: 2.5rem; line-height: 1.2;">Diseños únicos que cobran vida en repostería</h2>
        <p class="lead text-muted mb-5" style="font-weight: 300; font-size: 1.15rem;">
            En <strong>chokolocos</strong>, cada pastel, galleta y postre es una obra de arte diseñada a tu medida. Desde 2022 endulzamos tus celebraciones en la Ciudad de México y área metropolitana.
        </p>
        <div class="d-flex flex-column flex-sm-row justify-content-center justify-content-lg-start gap-3">
            <a class="btn btn-premium px-5 py-3 fs-5 shadow-sm" href="pasteles">
                <i class="fas fa-birthday-cake me-2"></i>Ver Pasteles
            </a>
            <a class="btn btn-premium-outline px-5 py-3 fs-5" href="pedidos">
                <i class="fab fa-whatsapp me-2"></i>Cotizar Ahora
            </a>
        </div>
    </div>
    <div class="col-lg-6 text-center">
        <div class="position-relative d-inline-block">
            <div class="hero-blob shadow-lg"></div>
            <img class="img-fluid rounded-circle shadow-lg border border-5 border-white animate-float position-relative"
                 src="img/cake/turin_1.jpg"
                 alt="Pastel Conejito Turin"
                 style="width: 420px; height: 420px; object-fit: cover; z-index: 2;" />
        </div>
    </div>
</section>


<!-- Featured Carousel -->
<section class="py-5 mb-5 bg-white rounded-5 shadow-sm p-4 p-md-5 reveal border border-1 border-light">
    <div class="text-center mb-5">
        <h2 class="font-heading display-4 fw-bold">Creaciones Destacadas</h2>
        <p class="text-muted fs-5">Los favoritos de nuestros clientes</p>
    </div>

    <div id="featuredCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#featuredCarousel" data-bs-slide-to="0" class="active bg-pink" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#featuredCarousel" data-bs-slide-to="1" class="bg-pink" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#featuredCarousel" data-bs-slide-to="2" class="bg-pink" aria-label="Slide 3"></button>
        </div>

        <div class="carousel-inner rounded-4" style="height: 450px;">
            <!-- Slide 1 -->
            <div class="carousel-item active h-100">
                <div class="row h-100 align-items-center bg-light p-4 rounded-4 m-0">
                    <div class="col-md-6 text-center text-md-start p-4">
                        <span class="badge bg-danger mb-2 px-3 py-2">Más Vendido</span>
                        <div class="d-webkit-box overflow-hidden" style="display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2;">
                            <h3 class="font-heading display-5 fw-bold mb-3">Pastel Conejito Turin</h3>
                        </div>
                        <p class="lead text-muted mb-4">Pan de chocolate húmedo relleno de crema de avellanas Turin, decorado con conejitos de chocolate y frosting suave.</p>
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="pasteles" class="btn btn-premium">Ver Detalles</a>
                        </div>
                    </div>
                    <div class="col-md-6 h-100 p-0 d-none d-md-block">
                        <img src="img/cake/turin_2.jpg" class="d-block w-100 h-100 object-fit-cover rounded-4" alt="Pastel Turin">
                    </div>
                </div>
            </div>
            <!-- Slide 2 -->
            <div class="carousel-item h-100">
                <div class="row h-100 align-items-center bg-light p-4 rounded-4 m-0">
                    <div class="col-md-6 text-center text-md-start p-4">
                        <span class="badge bg-pink-badge mb-2 px-3 py-2" style="background-color: var(--color-pink); color: white;">Clásico</span>
                        <div class="d-webkit-box overflow-hidden" style="display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2;">
                            <h3 class="font-heading display-5 fw-bold mb-3">Pastel Red Velvet</h3>
                        </div>
                        <p class="lead text-muted mb-4">El clásico terciopelo rojo con un toque de cocoa y un delicioso betún de queso crema suave y terso.</p>
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="pasteles" class="btn btn-premium">Ver Detalles</a>
                        </div>
                    </div>
                    <div class="col-md-6 h-100 p-0 d-none d-md-block">
                        <img src="img/cake/red_velvet_1.jpg" class="d-block w-100 h-100 object-fit-cover rounded-4" alt="Red Velvet">
                    </div>
                </div>
            </div>
            <!-- Slide 3 -->
            <div class="carousel-item h-100">
                <div class="row h-100 align-items-center bg-light p-4 rounded-4 m-0">
                    <div class="col-md-6 text-center text-md-start p-4">
                        <span class="badge bg-success mb-2 px-3 py-2">Personalizado</span>
                        <div class="d-webkit-box overflow-hidden" style="display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2;">
                            <h3 class="font-heading display-5 fw-bold mb-3">Cupcakes de Diseño</h3>
                        </div>
                        <p class="lead text-muted mb-4">Cupcakes personalizados para cumpleaños y eventos temáticos. Diseños en fondant y crema con sabores deliciosos.</p>
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="pasteles" class="btn btn-premium">Ver Detalles</a>
                        </div>
                    </div>
                    <div class="col-md-6 h-100 p-0 d-none d-md-block">
                        <img src="img/cake/cupcakes_1.jpg" class="d-block w-100 h-100 object-fit-cover rounded-4" alt="Cupcakes">
                    </div>
                </div>
            </div>
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#featuredCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon p-3 rounded-circle bg-pink" style="background-color: var(--color-pink);" aria-hidden="true"></span>
            <span class="visually-hidden">Anterior</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#featuredCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon p-3 rounded-circle bg-pink" style="background-color: var(--color-pink);" aria-hidden="true"></span>
            <span class="visually-hidden">Siguiente</span>
        </button>
    </div>
</section>


<!-- Categories Section -->
<section class="py-5 mb-5 reveal">
    <div class="text-center mb-5">
        <h2 class="font-heading display-4 fw-bold">Nuestras Especialidades</h2>
        <p class="text-muted fs-5">Descubre el sabor, diseño y creatividad en cada una de nuestras categorías</p>
    </div>
    <div class="row g-4">
        <!-- Category Pasteles -->
        <div class="col-md-6 col-lg-4">
            <div class="card glass-card hover-lift h-100 border-0 overflow-hidden">
                <div class="position-relative" style="height: 240px; overflow: hidden;">
                    <img src="img/cake/red_velvet_1.jpg" class="card-img-top w-100 h-100 object-fit-cover" alt="Pasteles Chokolocos">
                    <div class="category-badge">Pasteles</div>
                </div>
                <div class="card-body p-4 text-center">
                    <h3 class="font-heading h4 fw-bold mb-3">Pasteles & Cupcakes</h3>
                    <p class="text-muted mb-4">Pasteles personalizados en fondant o crema y cupcakes temáticos elaborados con ingredientes premium.</p>
                    <a class="btn btn-premium-outline w-100" href="pasteles">Ver Catálogo</a>
                </div>
            </div>
        </div>

        <!-- Category Tartas -->
        <div class="col-md-6 col-lg-4">
            <div class="card glass-card hover-lift h-100 border-0 overflow-hidden">
                <div class="position-relative" style="height: 240px; overflow: hidden;">
                    <img src="img/strudel/tarta_1.jpg" class="card-img-top w-100 h-100 object-fit-cover" alt="Tartas Chokolocos">
                    <div class="category-badge bg-pink">Tartas</div>
                </div>
                <div class="card-body p-4 text-center">
                    <h3 class="font-heading h4 fw-bold mb-3">Tartas & Pays</h3>
                    <p class="text-muted mb-4">Strudels de manzana hojaldrados y tartas de frutas frescas en tres tamaños: individual, tradicional y familiar.</p>
                    <a class="btn btn-premium-outline w-100" href="tartas">Ver Tamaños</a>
                </div>
            </div>
        </div>

        <!-- Category Galletas -->
        <div class="col-md-6 col-lg-4">
            <div class="card glass-card hover-lift h-100 border-0 overflow-hidden">
                <div class="position-relative" style="height: 240px; overflow: hidden;">
                    <img src="img/cookie/bluey.jpg" class="card-img-top w-100 h-100 object-fit-cover" alt="Galletas Temáticas">
                    <div class="category-badge bg-mint">Galletas</div>
                </div>
                <div class="card-body p-4 text-center">
                    <h3 class="font-heading h4 fw-bold mb-3">Galletas Temáticas</h3>
                    <p class="text-muted mb-4">Galletas de mantequilla decoradas meticulosamente con Royal Icing. Diseños y personajes a la medida.</p>
                    <a class="btn btn-premium-outline w-100" href="galletas">Ver Diseños</a>
                </div>
            </div>
        </div>

        <!-- Category Cortadores -->
        <div class="col-md-6 col-lg-4">
            <div class="card glass-card hover-lift h-100 border-0 overflow-hidden">
                <div class="position-relative" style="height: 240px; overflow: hidden;">
                    <img src="img/cookie_cutters/cortadores_galleta_bautiso.jpg" class="card-img-top w-100 h-100 object-fit-cover" alt="Cortadores de galleta">
                    <div class="category-badge bg-mint">Impresión 3D</div>
                </div>
                <div class="card-body p-4 text-center">
                    <h3 class="font-heading h4 fw-bold mb-3">Cortadores de Galleta</h3>
                    <p class="text-muted mb-4">Cortadores personalizados en PLA ecológico grado alimenticio. Diseños a medida de hasta 20 cm.</p>
                    <a class="btn btn-premium-outline w-100" href="cortadores">Personalizar</a>
                </div>
            </div>
        </div>

        <!-- Category Arreglos -->
        <div class="col-md-6 col-lg-4">
            <div class="card glass-card hover-lift h-100 border-0 overflow-hidden">
                <div class="position-relative" style="height: 240px; overflow: hidden;">
                    <img src="img/gift/rosas_chocolate.jpg" class="card-img-top w-100 h-100 object-fit-cover" alt="Arreglos Comestibles">
                    <div class="category-badge bg-dark">Regalos</div>
                </div>
                <div class="card-body p-4 text-center">
                    <h3 class="font-heading h4 fw-bold mb-3">Arreglos Comestibles</h3>
                    <p class="text-muted mb-4">Ramos de fresas con chocolate con forma de rosa y ramos de galletas florales. El regalo comestible ideal.</p>
                    <a class="btn btn-premium-outline w-100" href="arreglos">Ver Detalles</a>
                </div>
            </div>
        </div>

        <!-- Category Pedidos -->
        <div class="col-md-6 col-lg-4">
            <div class="card glass-card hover-lift h-100 border-0 overflow-hidden">
                <div class="position-relative" style="height: 240px; overflow: hidden;">
                    <img src="img/cookie/san_valentin_1.jpg" class="card-img-top w-100 h-100 object-fit-cover" alt="Pedidos Personalizados">
                    <div class="category-badge bg-dark">Pedidos</div>
                </div>
                <div class="card-body p-4 text-center">
                    <h3 class="font-heading h4 fw-bold mb-3">Pedidos Especiales</h3>
                    <p class="text-muted mb-4">¿Tienes una temática en mente? Escríbenos directamente y creamos una cotización personalizada de inmediato.</p>
                    <a class="btn btn-premium w-100" href="pedidos"><i class="fab fa-whatsapp me-2"></i>Cotizar Evento</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Social & Social Feed Section -->
<section class="py-5 mb-5 reveal">
    <div class="text-center mb-5">
        <h2 class="font-heading display-4 fw-bold">Nuestra Comunidad</h2>
        <p class="text-muted fs-5">Síguenos en nuestras redes sociales para enterarte de nuevos lanzamientos</p>
    </div>

    <!-- Redes Links -->
    <div class="d-flex justify-content-center gap-3 mb-5">
        <a class="btn btn-primary btn-lg rounded-circle d-flex align-items-center justify-content-center hover-lift" style="background-color: #3b5998; width: 60px; height: 60px;" href="https://www.facebook.com/103492021490449" target="_blank">
            <i class="fab fa-facebook-f fa-lg"></i>
        </a>
        <a class="btn btn-primary btn-lg rounded-circle d-flex align-items-center justify-content-center hover-lift" style="background-color: #ac2bac; width: 60px; height: 60px;" href="https://www.instagram.com/choko.locos" target="_blank">
            <i class="fab fa-instagram fa-lg"></i>
        </a>
        <a class="btn btn-primary btn-lg rounded-circle d-flex align-items-center justify-content-center hover-lift" style="background-color: #333333; width: 60px; height: 60px;" href="https://www.tiktok.com/@@chokolocos.2" target="_blank">
            <i class="fab fa-tiktok fa-lg"></i>
        </a>
        <a class="btn btn-primary btn-lg rounded-circle d-flex align-items-center justify-content-center hover-lift" style="background-color: #25d366; width: 60px; height: 60px;" href="https://wa.me/15511960974" target="_blank">
            <i class="fab fa-whatsapp fa-lg"></i>
        </a>
    </div>

    <!-- Social Feeds -->
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-2">
                    <h4 class="font-heading fw-bold m-0"><i class="fab fa-facebook me-2 text-primary"></i>Publicaciones de Facebook</h4>
                    <a href="https://www.facebook.com/103492021490449" target="_blank" class="small text-pink text-decoration-none" style="color: var(--color-pink);">Ver Página</a>
                </div>
                <iframe src="https://widgets.sociablekit.com/facebook-page-posts/iframe/25662907" frameborder="0" width="100%" height="450px" class="rounded-3"></iframe>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-2">
                    <h4 class="font-heading fw-bold m-0"><i class="fab fa-instagram me-2 text-danger"></i>Feed de Instagram</h4>
                    <a href="https://www.instagram.com/choko.locos" target="_blank" class="small text-pink text-decoration-none" style="color: var(--color-pink);">Ver Perfil</a>
                </div>
                <iframe src="https://widgets.sociablekit.com/instagram-feed/iframe/25662901" frameborder="0" width="100%" height="450px" class="rounded-3"></iframe>
            </div>
        </div>
    </div>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("inicializarCatalogo");
        }
    }
}
