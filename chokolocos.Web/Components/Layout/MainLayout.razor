@inherits LayoutComponentBase

<div class="page-container d-flex flex-column" style="min-height: 100vh;">
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-background py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" href="">
                    <img src="img/chokolocos_icon.png" alt="Logo" width="38" height="38" class="d-inline-block align-top me-2 animate-float">
                    <span class="deli-cake h2 mb-0 text-color-pink" style="color: var(--color-pink); font-weight: bold; letter-spacing: 1px;">chokolocos</span>
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNavDropdown">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item my-1 my-lg-0">
                            <NavLink class="nav-link nav-link-animated mx-3 px-0" href="" Match="NavLinkMatch.All">Inicio</NavLink>
                        </li>
                        <li class="nav-item dropdown my-1 my-lg-0">
                            <a class="nav-link dropdown-toggle nav-link-animated mx-3 px-0" href="#" id="navbarDropdownMenuLink" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Catálogo
                            </a>
                            <ul class="dropdown-menu border-0 shadow-lg rounded-3 py-2 mt-2" aria-labelledby="navbarDropdownMenuLink" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);">
                                <li><NavLink class="dropdown-item py-2 px-3 fw-medium" href="pasteles">Pasteles & Cupcakes</NavLink></li>
                                <li><NavLink class="dropdown-item py-2 px-3 fw-medium" href="tartas">Tartas & Pays</NavLink></li>
                                <li><NavLink class="dropdown-item py-2 px-3 fw-medium" href="galletas">Galletas Decoradas</NavLink></li>
                                <li><NavLink class="dropdown-item py-2 px-3 fw-medium" href="cortadores">Cortadores de Galleta</NavLink></li>
                                <li><NavLink class="dropdown-item py-2 px-3 fw-medium" href="arreglos">Arreglos Comestibles</NavLink></li>
                            </ul>
                        </li>
                        <li class="nav-item my-1 my-lg-0">
                            <NavLink class="nav-link nav-link-animated mx-3 px-0" href="pedidos">Pedidos</NavLink>
                        </li>
                        <li class="nav-item my-1 my-lg-0">
                            <NavLink class="nav-link nav-link-animated mx-3 px-0" href="about">Nosotros</NavLink>
                        </li>
                        <li class="nav-item ms-lg-3 mt-2 mt-lg-0">
                            <a class="btn btn-premium px-4 py-2" href="pedidos">
                                <i class="fab fa-whatsapp me-2"></i>Cotizar
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <div id="blazor-error-ui">
            Un error inesperado ha ocurrido.
            <a href="" class="reload">Recargar</a>
            <a class="dismiss">🗙</a>
        </div>
    </header>

    <main class="flex-grow-1">
        <div class="bg-color py-4">
            <div class="container animate-fade-in-up">
                @Body
            </div>
        </div>
    </main>

    <footer class="py-5" style="background-color: var(--color-dark); color: rgba(255, 255, 255, 0.7); border-top: 3px solid var(--color-pink);">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-4 mb-md-0">
                    <div class="d-flex align-items-center justify-content-center justify-content-md-start mb-3">
                        <img src="img/chokolocos_icon.png" alt="Logo" width="40" height="40" class="me-2">
                        <span class="deli-cake h3 mb-0 text-white">chokolocos</span>
                    </div>
                    <p class="mb-0 text-white-50" style="max-width: 400px; font-weight: 300;">
                        Creamos repostería artística personalizada de alta calidad para endulzar tus momentos especiales desde 2022.
                    </p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <div class="social-icons mb-3">
                        <a href="https://www.facebook.com/103492021490449" target="_blank" class="text-white-50 mx-2 hover-pink"><i class="fab fa-facebook-f fa-lg"></i></a>
                        <a href="https://www.instagram.com/choko.locos" target="_blank" class="text-white-50 mx-2 hover-pink"><i class="fab fa-instagram fa-lg"></i></a>
                        <a href="https://www.tiktok.com/@@chokolocos.2" target="_blank" class="text-white-50 mx-2 hover-pink"><i class="fab fa-tiktok fa-lg"></i></a>
                        <a href="https://wa.me/15511960974" target="_blank" class="text-white-50 mx-2 hover-pink"><i class="fab fa-whatsapp fa-lg"></i></a>
                    </div>
                    <p class="mb-0 text-white-50 small">&copy; @DateTime.Now.Year chokolocos. Hecho con amor por Leesly Meléndez.</p>
                </div>
            </div>
        </div>
    </footer>
</div>

<style>
    .hover-pink:hover {
        color: var(--color-pink) !important;
        transition: color 0.2s;
    }
    .dropdown-item {
        color: var(--color-dark);
        transition: background-color 0.2s, color 0.2s;
    }
    .dropdown-item:hover {
        background-color: var(--color-pink-light);
        color: var(--color-pink-dark);
    }
    .dropdown-item.active, .dropdown-item:active {
        background-color: var(--color-pink);
        color: white;
    }
    /* Hover dropdown on desktop */
    @@media (min-width: 992px) {
        .nav-item.dropdown:hover .dropdown-menu {
            display: block;
            margin-top: 0; 
        }
    }
</style>
